# ===========================================
# SMART PEN v2.0 WEBSOCKET ENVIRONMENT CONFIGURATION
# ===========================================

# Application Environment
NODE_ENV=development
APP_NAME=Smart Pen v2.0 WebSocket System
APP_VERSION=2.0.0
APP_URL=http://localhost:3004
API_URL=http://localhost:5000

# Server Configuration
PORT=5000
HOST=0.0.0.0

# WebSocket Configuration
WS_PORT=5000
WS_PATH=/ws
WS_HEARTBEAT_INTERVAL=30000

# Database Configuration
DATABASE_URL=postgresql://smartpen_user:smartpen_password@postgres:5432/smartpen_db
POSTGRES_DB=smartpen_db
POSTGRES_USER=smartpen_user
POSTGRES_PASSWORD=smartpen_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3004,http://localhost

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@smartpen.com

# ESP32 Device Configuration
WIFI_SSID=your-wifi-network
WIFI_PASSWORD=your-wifi-password
SERVER_HOST=192.168.1.100
SERVER_PORT=5000
ESP32_WS_URL=ws://192.168.1.100:5000/ws

# Frontend Configuration (WebSocket Support)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_WS_URL=ws://localhost:5000/ws
VITE_API_URL=http://localhost:5000/api

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-in-production

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=logs

# Features Configuration
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_COMPRESSION=true
ENABLE_HELMET=true

# Docker-specific overrides (for containerized deployment)
# DATABASE_URL=postgresql://smartpen_user:smartpen_password@postgres:5432/smartpen_db
# REDIS_URL=redis://redis:6379

# Production Overrides (uncomment for production)
# NODE_ENV=production
# APP_URL=https://smartpen.com
# API_URL=https://api.smartpen.com
# VITE_WS_URL=wss://api.smartpen.com/ws
# DATABASE_URL=postgresql://user:password@prod-db:5432/smartpen_prod 